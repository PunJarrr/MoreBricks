{
	"schemaVersion": 1,
	"id": "morebricks",
	"version": "${version}",
	"name": "MoreBricks",
	"description": "Add andesite, diorite, granite bricks to Minecraft!",
	"authors":
	[
		"PunJarrr"
	],
	"contact":
	{
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/morebricks/icon.png",
	"environment": "*",
	"entrypoints":
	{
